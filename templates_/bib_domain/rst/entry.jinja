{# Jinja Template for Bibtex -> rst export -#}
{% set roles = [
"author", "editor", "title", "subtitle", "year",
"booktitle", "journal", "publisher", "institution",
"series", "number", "volume", "chapter", "country",
"short_parties", "edition", "edition_year",
"isbn", "identifier", "tags",  "doi", "url",
] -%}

{% block header %} {% endblock header %}

  
{% block body %}
.. bibtex:entry:: {{ key }}
  :etype: {{ entry_type }}
  {% for key,val in entry|items %}
    {%   if key == "author" or key == "editor" %}
  {{ (':' ~ key ~ ':  ' ~ val.value|join(" | ")) }}
    {%   elif key in roles and val.value is ne("") %}
  {{ (':' ~ key ~ ':  ' ~ val.value) }}
    {%   endif %}
  {% endfor %}

{% endblock body %}

{% block footer %}
----
{% endblock footer %}
